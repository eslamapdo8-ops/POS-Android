<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/gray_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- بطاقة ملخص اليوم -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_sales"
                    android:textSize="@dimen/text_lg"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tv_today_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 ر.س"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tv_today_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 عملية بيع"
                    android:textSize="@dimen/text_md"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- عنوان قائمة المبيعات -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="آخر المبيعات"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:layout_marginStart="@dimen/spacing_sm" />

        <!-- قائمة المبيعات -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sales"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- حالة فارغة -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لا توجد مبيعات اليوم"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/gray"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_xl"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
